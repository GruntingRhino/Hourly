# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled recommended for Vercel)
DATABASE_URL=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-here

# ─── App URLs ─────────────────────────────────────────────────────────────────
APP_URL=https://goodhours.app
CLIENT_URL=https://goodhours.app
PORT=3001

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
# Authorized origins: https://goodhours.app
# Authorized redirect URIs: https://goodhours.app/school/register
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key
# Verified sending domain required — e.g. notifications.goodhours.app
EMAIL_FROM=GoodHours <noreply@notifications.goodhours.app>
